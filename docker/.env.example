# Host UID/GID — コンテナ内 developer ユーザーに反映（ホストと一致させること）
UID=1002
GID=1002

# 使用する GPU の UUID（排他運用前提）
# 取得方法: nvidia-smi -L | awk -F'UUID: ' '{print $2}' | tr -d ')'
GPU_UUID=GPU-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ホスト側データ配置（存在し、takenouchi 所有で書き込み可能であること）
# 規約:
#   datasets/  /mnt/ssd2/takenouchi/aixsuture/datasets (SATA, 大容量 read-only、96GB+)
#   weights/   /home/takenouchi/AIxSuture/weights       (NVMe, read-only)
#   runs/      /home/takenouchi/AIxSuture/runs          (NVMe, read-write; runs/aixsuture, runs/sam3 に分岐)
# weights/runs が repo 直下に位置するため .gitignore と .dockerignore で除外済み。
DATASETS_DIR=/mnt/ssd2/takenouchi/aixsuture/datasets
WEIGHTS_DIR=/home/takenouchi/AIxSuture/weights
RUNS_DIR=/home/takenouchi/AIxSuture/runs
